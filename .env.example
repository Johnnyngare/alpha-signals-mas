cat > .env.example << 'EOF'


# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=@your_channel_handle

# The-Odds-API Configuration
# Free tier: 500 requests/month
# Get your key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key

# Subscription System
# The plaintext token for your own subscriber access
SUBSCRIBER_TOKEN=your_plaintext_token_here
# Salt used to hash subscriber tokens
SUBSCRIPTION_SALT=alpha_signals_default_salt

EOF